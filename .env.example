# OddWise frontend — backend Spring Boot em ../backend
#
# Desenvolvimento (npm run dev):
#   VITE_API_BASE_URL=          → usa proxy do Vite em /api
#   VITE_BACKEND_URL=           → destino do proxy (Spring Boot)
#
# Produção (npm run build):
#   VITE_API_BASE_URL=http://localhost:8080

VITE_API_BASE_URL=
VITE_BACKEND_URL=http://localhost:8080
